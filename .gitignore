# Ignore frontend node_modules
/frontend/node_modules/

# ── Gradle build outputs ──────────────────────────────────────────
**/build/
**/.gradle/
**/bin/

# ── Compiled Java class files & JARs ─────────────────────────────
**/*.class
**/*.jar
**/*.war
**/*.ear

# ── IDE files ─────────────────────────────────────────────────────
**/.project
**/.classpath
**/.settings/
**/.idea/
**/*.iml

# ── Angular cache ─────────────────────────────────────────────────
frontend/.angular/cache/
